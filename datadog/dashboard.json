{
  "title": "TRAKSHYA WAF - Security Overview",
  "description": "Real-time monitoring dashboard for TRAKSHYA Web Application Firewall",
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Requests & Blocks per Second",
        "requests": [
          {
            "q": "sum:trakshya_waf.waf_requests_total{service:trakshya-waf}.as_rate()",
            "display_type": "line",
            "style": {
              "palette": "green"
            }
          },
          {
            "q": "sum:trakshya_waf.waf_blocked_total{service:trakshya-waf}.as_rate()",
            "display_type": "line",
            "style": {
              "palette": "red"
            }
          }
        ],
        "yaxis": {
          "scale": "linear"
        }
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 8,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Request Latency (P50 / P95 / P99)",
        "requests": [
          {
            "q": "p50:trakshya_waf.waf_request_duration_seconds{service:trakshya-waf}",
            "display_type": "line",
            "style": {
              "palette": "blue"
            }
          },
          {
            "q": "p95:trakshya_waf.waf_request_duration_seconds{service:trakshya-waf}",
            "display_type": "line",
            "style": {
              "palette": "yellow"
            }
          },
          {
            "q": "p99:trakshya_waf.waf_request_duration_seconds{service:trakshya-waf}",
            "display_type": "line",
            "style": {
              "palette": "orange"
            }
          }
        ]
      },
      "layout": {
        "x": 8,
        "y": 0,
        "width": 8,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Upstream Timeouts",
        "requests": [
          {
            "q": "sum:trakshya_waf.waf_upstream_timeouts_total{service:trakshya-waf}.as_rate()",
            "display_type": "bars",
            "style": {
              "palette": "purple"
            }
          }
        ]
      },
      "layout": {
        "x": 16,
        "y": 0,
        "width": 8,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Total Blocks Today",
        "requests": [
          {
            "q": "sum:trakshya_waf.waf_blocked_total{service:trakshya-waf}",
            "aggregator": "sum"
          }
        ],
        "autoscale": true
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 4,
        "height": 2
      }
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Active Connections",
        "requests": [
          {
            "q": "avg:trakshya_waf.waf_active_connections{service:trakshya-waf}",
            "aggregator": "avg"
          }
        ],
        "autoscale": true
      },
      "layout": {
        "x": 4,
        "y": 4,
        "width": 4,
        "height": 2
      }
    },
    {
      "definition": {
        "type": "toplist",
        "title": "Blocks by Threat Category",
        "requests": [
          {
            "q": "top(sum:trakshya_waf.waf_blocked_total{service:trakshya-waf} by {category}, 10, 'max', 'desc')",
            "style": {
              "palette": "warm"
            }
          }
        ]
      },
      "layout": {
        "x": 8,
        "y": 4,
        "width": 8,
        "height": 4
      }
    },
    {
      "definition": {
        "type": "log_stream",
        "title": "Recent Security Events",
        "query": "service:trakshya-waf AND (\"SQLi\" OR \"XSS\" OR \"CMDi\" OR \"BLOCKED\")",
        "columns": [
          "timestamp",
          "host",
          "service",
          "status"
        ],
        "sort": {
          "order": "desc",
          "column": "timestamp"
        }
      },
      "layout": {
        "x": 16,
        "y": 4,
        "width": 8,
        "height": 6
      }
    }
  ],
  "layout_type": "free",
  "notify_list": [
    "slayer-sre@example.com"
  ],
  "tags": [
    "app:trakshya-waf",
    "team:security"
  ]
}
